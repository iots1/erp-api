# ──────────────────────────────────────────────────────────────
#  General
# ──────────────────────────────────────────────────────────────
NODE_ENV=dev
LOG_LEVEL=debug
# Max time (ms) a service waits for in-flight HTTP/RPC work to drain on
# SIGTERM/SIGINT before force-exiting. See graceful-shutdown.service.ts.
SHUTDOWN_TIMEOUT_MS=30000

# ──────────────────────────────────────────────────────────────
#  OpenTelemetry tracing (see libs/common/src/tracing.ts)
# ──────────────────────────────────────────────────────────────
# "false" disables tracing entirely (default: enabled)
OTEL_TRACES_ENABLED=true
# service.name reported to the collector. Left unset in dev — falls back to
# the app name parsed from the entry path (e.g. "iam"). Set per-app in
# production so traces from `dist/apps/<name>/main.js` are unambiguous.
# OTEL_SERVICE_NAME=
# Collector (Alloy/OTel Collector) OTLP gRPC endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317

# ──────────────────────────────────────────────────────────────
#  Security
# ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
# 32-byte hex string (64 chars) — AES-256-GCM key encrypting Access Key secret keys at rest (iam-bc)
ACCESS_KEY_SECRET_ENCRYPTION_KEY=change-me-64-char-hex-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookie attributes for the browser (httpOnly access/refresh token + CSRF
# double-submit) auth flow. COOKIE_DOMAIN left unset in dev (defaults to the
# exact request host); COOKIE_SECURE=false only for local plain-HTTP dev.
# COOKIE_DOMAIN=
COOKIE_SECURE=false
# credentials:true CORS requires an explicit origin — never "*" once cookies are
# involved (browsers reject that combination on any credentialed request).
# Comma-separate multiple origins, e.g. http://localhost:3002,https://admin.xxx.com
CORS_ORIGIN=http://localhost:3002
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# ──────────────────────────────────────────────────────────────
#  Inter-service transport
#  TRANSPORT=rmq (default) uses RabbitMQ; set TRANSPORT=tcp to fall back to
#  direct TCP if the broker is unavailable (both client + server switch together).
# ──────────────────────────────────────────────────────────────
TRANSPORT=rmq
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# ──────────────────────────────────────────────────────────────
#  Redis (stateful auth sessions + CSRF tokens)
# ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0
AUTH_SESSION_TTL=604800

# ──────────────────────────────────────────────────────────────
#  Databases (one per Bounded Context — `auth` stores only credentials/
#  refresh_tokens/login_histories/blocked_users/security_logs, no user profile data)
# ──────────────────────────────────────────────────────────────
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USERNAME=postgres
AUTH_DB_PASSWORD=postgres
AUTH_DB_NAME=erp_auth

IAM_DB_HOST=localhost
IAM_DB_PORT=5432
IAM_DB_USERNAME=postgres
IAM_DB_PASSWORD=postgres
IAM_DB_NAME=erp_iam

INVENTORY_DB_HOST=localhost
INVENTORY_DB_PORT=5432
INVENTORY_DB_USERNAME=postgres
INVENTORY_DB_PASSWORD=postgres
INVENTORY_DB_NAME=erp_inventory
# Dev-only: auto-create/update schema from entities (no migrations yet for Phase 2 master data).
INVENTORY_DB_SYNCHRONIZE=true

SUPPLIER_DB_HOST=localhost
SUPPLIER_DB_PORT=5432
SUPPLIER_DB_USERNAME=postgres
SUPPLIER_DB_PASSWORD=postgres
SUPPLIER_DB_NAME=erp_supplier
SUPPLIER_DB_SYNCHRONIZE=true

SALES_DB_HOST=localhost
SALES_DB_PORT=5432
SALES_DB_USERNAME=postgres
SALES_DB_PASSWORD=postgres
SALES_DB_NAME=erp_sales

FINANCE_DB_HOST=localhost
FINANCE_DB_PORT=5432
FINANCE_DB_USERNAME=postgres
FINANCE_DB_PASSWORD=postgres
FINANCE_DB_NAME=erp_finance

REPORT_DB_HOST=localhost
REPORT_DB_PORT=5432
REPORT_DB_USERNAME=postgres
REPORT_DB_PASSWORD=postgres
REPORT_DB_NAME=erp_report

# Storage BC is stateless — no database, connects to an S3-compatible bucket (MinIO)
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_ID=minioadmin
STORAGE_S3_SECRET_ACCESS_KEY=minioadmin
STORAGE_S3_BUCKET=erp-storage
STORAGE_S3_FORCE_PATH_STYLE=true

# ──────────────────────────────────────────────────────────────
#  Services (HTTP + TCP microservice ports)
# ──────────────────────────────────────────────────────────────
AUTH_PREFIX_NAME=auth
AUTH_PREFIX_VERSION=v1
AUTH_MODULE_HTTP_PORT=3001
# Browser-reachable origin for auth-bc (used by the iam-view admin UI, which is
# served by iam-bc and calls auth-bc cross-origin for login/refresh/logout).
# Defaults to http://localhost:<AUTH_MODULE_HTTP_PORT> if unset.
AUTH_PUBLIC_URL=http://localhost:3001
AUTH_MODULE_MICROSERVICE_HOST=localhost
AUTH_MODULE_MICROSERVICE_PORT=4001

IAM_PREFIX_NAME=iam
IAM_PREFIX_VERSION=v1
IAM_MODULE_HTTP_PORT=3002
IAM_MODULE_MICROSERVICE_HOST=localhost
IAM_MODULE_MICROSERVICE_PORT=4002

INVENTORY_PREFIX_NAME=inventory
INVENTORY_PREFIX_VERSION=v1
INVENTORY_BC_MODULE_HTTP_PORT=3003
INVENTORY_BC_MODULE_MICROSERVICE_HOST=localhost
INVENTORY_BC_MODULE_MICROSERVICE_PORT=4003

SUPPLIER_PREFIX_NAME=supplier
SUPPLIER_PREFIX_VERSION=v1
SUPPLIER_BC_MODULE_HTTP_PORT=3004
SUPPLIER_BC_MODULE_MICROSERVICE_HOST=localhost
SUPPLIER_BC_MODULE_MICROSERVICE_PORT=4004

SALES_PREFIX_NAME=sales
SALES_PREFIX_VERSION=v1
SALES_BC_MODULE_HTTP_PORT=3005
SALES_BC_MODULE_MICROSERVICE_HOST=localhost
SALES_BC_MODULE_MICROSERVICE_PORT=4005

FINANCE_PREFIX_NAME=finance
FINANCE_PREFIX_VERSION=v1
FINANCE_BC_MODULE_HTTP_PORT=3006
FINANCE_BC_MODULE_MICROSERVICE_HOST=localhost
FINANCE_BC_MODULE_MICROSERVICE_PORT=4006

REPORT_PREFIX_NAME=report
REPORT_PREFIX_VERSION=v1
REPORT_BC_MODULE_HTTP_PORT=3007
REPORT_BC_MODULE_MICROSERVICE_HOST=localhost
REPORT_BC_MODULE_MICROSERVICE_PORT=4007

STORAGE_PREFIX_NAME=storage
STORAGE_PREFIX_VERSION=v1
STORAGE_MODULE_HTTP_PORT=3008
STORAGE_MODULE_MICROSERVICE_HOST=localhost
STORAGE_MODULE_MICROSERVICE_PORT=4008
