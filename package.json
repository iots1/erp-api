{
  "name": "erp-api",
  "version": "0.0.1",
  "description": "Enterprise ERP backend (NestJS microservices monorepo)",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "graph": "nx graph",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "build:auth": "nest build auth",
    "build:iam": "nest build iam",
    "build:inventory-bc": "nest build inventory-bc",
    "build:supplier-bc": "nest build supplier-bc",
    "build:sales-bc": "nest build sales-bc",
    "build:finance-bc": "nest build finance-bc",
    "build:report-bc": "nest build report-bc",
    "build:storage": "nest build storage",
    "build:all": "for app in auth iam inventory-bc supplier-bc sales-bc finance-bc report-bc storage; do echo \"Building $app...\" && nest build $app; done",
    "start:dev:auth": "nest start auth --watch | pino-pretty -c -t -l",
    "start:dev:iam": "nest start iam --watch | pino-pretty -c -t -l",
    "start:dev:inventory-bc": "nest start inventory-bc --watch | pino-pretty -c -t -l",
    "start:dev:supplier-bc": "nest start supplier-bc --watch | pino-pretty -c -t -l",
    "start:dev:sales-bc": "nest start sales-bc --watch | pino-pretty -c -t -l",
    "start:dev:finance-bc": "nest start finance-bc --watch | pino-pretty -c -t -l",
    "start:dev:report-bc": "nest start report-bc --watch | pino-pretty -c -t -l",
    "start:dev:storage": "nest start storage --watch | pino-pretty -c -t -l",
    "start:dev:all": "concurrently --names \"AUTH,IAM,INV,SUP,SALES,FIN,REP,STO\" --prefix-colors \"magenta,red,blue,green,yellow,cyan,white,gray\" \"npm:start:dev:auth\" \"npm:start:dev:iam\" \"npm:start:dev:inventory-bc\" \"npm:start:dev:supplier-bc\" \"npm:start:dev:sales-bc\" \"npm:start:dev:finance-bc\" \"npm:start:dev:report-bc\" \"npm:start:dev:storage\"",
    "start:prod:auth": "node dist/apps/auth/main",
    "start:prod:iam": "node dist/apps/iam/main",
    "permissions:sync": "ts-node -r tsconfig-paths/register libs/database/src/scripts/sync-permissions.script.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:auth": "npm run typeorm -- -d libs/database/src/data-source/data-source.auth.ts",
    "typeorm:iam": "npm run typeorm -- -d libs/database/src/data-source/data-source.iam.ts",
    "typeorm:inventory": "npm run typeorm -- -d libs/database/src/data-source/data-source.inventory.ts",
    "typeorm:supplier": "npm run typeorm -- -d libs/database/src/data-source/data-source.supplier.ts",
    "typeorm:sales": "npm run typeorm -- -d libs/database/src/data-source/data-source.sales.ts",
    "typeorm:finance": "npm run typeorm -- -d libs/database/src/data-source/data-source.finance.ts",
    "typeorm:report": "npm run typeorm -- -d libs/database/src/data-source/data-source.report.ts",
    "migration:run:auth": "npm run typeorm:auth -- migration:run",
    "migration:run:iam": "npm run typeorm:iam -- migration:run",
    "migration:run:inventory": "npm run typeorm:inventory -- migration:run",
    "migration:run:supplier": "npm run typeorm:supplier -- migration:run",
    "migration:run:sales": "npm run typeorm:sales -- migration:run",
    "migration:run:finance": "npm run typeorm:finance -- migration:run",
    "migration:run:report": "npm run typeorm:report -- migration:run",
    "migration:run:all": "npm run migration:run:auth && npm run migration:run:iam && npm run migration:run:inventory && npm run migration:run:supplier && npm run migration:run:sales && npm run migration:run:finance && npm run migration:run:report",
    "migration:generate:auth": "npm run typeorm:auth -- migration:generate libs/database/src/migrations/erp_auth/$npm_config_name",
    "migration:generate:iam": "npm run typeorm:iam -- migration:generate libs/database/src/migrations/erp_iam/$npm_config_name",
    "migration:generate:inventory": "npm run typeorm:inventory -- migration:generate libs/database/src/migrations/erp_inventory/$npm_config_name",
    "migration:generate:supplier": "npm run typeorm:supplier -- migration:generate libs/database/src/migrations/erp_supplier/$npm_config_name",
    "migration:generate:sales": "npm run typeorm:sales -- migration:generate libs/database/src/migrations/erp_sales/$npm_config_name",
    "migration:generate:finance": "npm run typeorm:finance -- migration:generate libs/database/src/migrations/erp_finance/$npm_config_name",
    "migration:generate:report": "npm run typeorm:report -- migration:generate libs/database/src/migrations/erp_report/$npm_config_name",
    "migration:revert:auth": "npm run typeorm:auth -- migration:revert",
    "migration:revert:iam": "npm run typeorm:iam -- migration:revert",
    "migration:revert:inventory": "npm run typeorm:inventory -- migration:revert",
    "migration:revert:supplier": "npm run typeorm:supplier -- migration:revert",
    "migration:revert:sales": "npm run typeorm:sales -- migration:revert",
    "migration:revert:finance": "npm run typeorm:finance -- migration:revert",
    "migration:revert:report": "npm run typeorm:report -- migration:revert"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
  "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.2",
   "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.0",
"@nestjs/microservices": "^11.1.28",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@scalar/nestjs-api-reference": "1.0.15",
    "@socket.io/redis-adapter": "^8.3.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dayjs": "^1.11.19",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "fastify": "^5.8.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "joi": "^18.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.26",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
   "@nestjs/testing": "^11.1.28",
    "@nx/eslint": "23.0.1",
    "@nx/jest": "23.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/ejs": "^3.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "nx": "23.0.1",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "moduleNameMapper": {
      "^@lib/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@lib/config(|/.*)$": "<rootDir>/libs/config/src/$1",
      "^@lib/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@lib/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1"
    }
  }
}
