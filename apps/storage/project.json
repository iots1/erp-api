{
  "name": "storage",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/storage/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build storage"
      },
      "outputs": ["{workspaceRoot}/dist/apps/storage"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start storage --watch | pino-pretty -c -t -l"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/storage/jest.config.js",
        "passWithNoTests": true
      }
    },
    "test:e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/storage/test/jest-e2e.json",
        "passWithNoTests": true
      }
    }
  }
}
