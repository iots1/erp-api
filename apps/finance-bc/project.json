{
  "name": "finance-bc",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/finance-bc/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build finance-bc"
      },
      "outputs": ["{workspaceRoot}/dist/apps/finance-bc"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start finance-bc --watch | pino-pretty -c -t -l"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/finance-bc/jest.config.js",
        "passWithNoTests": true
      }
    },
    "test:e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/finance-bc/test/jest-e2e.json",
        "passWithNoTests": true
      }
    }
  }
}
