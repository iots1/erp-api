<!-- ═══════════ Initial login screen ═══════════ -->
<div id="loginScreen" class="um-login-screen">
    <article class="um-login-card">
        <div class="um-login-brand">
            <div class="um-login-logo">E</div>
            <span>ERP IAM Admin</span>
        </div>
        <p class="um-login-subtitle">เข้าสู่ระบบจัดการสิทธิ์ผู้ใช้งาน</p>
        <form id="loginForm" onsubmit="handleInitialLoginSubmit(event)">
            <%- include('../ui/field', { id: 'loginUsername', label: 'ชื่อผู้ใช้งาน', required: true, autocomplete: 'username', autofocus: true }) %>
            <%- include('../ui/field', { id: 'loginPassword', label: 'รหัสผ่าน', type: 'password', required: true, autocomplete: 'current-password' }) %>
            <p id="loginError" class="auth-modal-error hidden"></p>
            <button type="submit" class="p-btn p-btn-sky um-login-submit">เข้าสู่ระบบ</button>
        </form>
    </article>
</div>
