<!-- Forced re-login on session expiry (no close button — the user must
     re-authenticate to continue). handleAuthLogin is bridged to window by
     each page's controller/public-api.js; see auth-guard.service.js. -->
<dialog id="authLoginModal" data-persistent>
    <article>
        <h3>เซสชันหมดอายุ</h3>
        <p>กรุณาเข้าสู่ระบบอีกครั้งเพื่อดำเนินการต่อ</p>
        <form id="authLoginForm" onsubmit="handleAuthLogin(event)">
            <%- include('ui/field', { id: 'authModalUsername', label: 'ชื่อผู้ใช้งาน', required: true, autocomplete: 'username' }) %>
            <%- include('ui/field', { id: 'authModalPassword', label: 'รหัสผ่าน', type: 'password', required: true, autocomplete: 'current-password' }) %>
            <p id="authModalError" class="auth-modal-error hidden"></p>
            <button type="submit" class="p-btn p-btn-lavender auth-modal-submit">เข้าสู่ระบบ</button>
        </form>
    </article>
</dialog>
