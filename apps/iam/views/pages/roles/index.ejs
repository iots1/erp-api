<%- include('../../components/layout/page-head', { pageName: 'roles' }) %>
<%
const topbarActions = [
    { btnClass: 'p-btn p-btn-sky p-btn-sm', icon: 'plus', label: 'สร้าง Role', onClick: `location.href='/${prefix}/views/roles/new'`, permission: 'role:create' },
];
%>
<%- include('../../components/admin-shell/shell-open', { activeView: 'roles', pageTitle: 'สิทธิ์การใช้งาน (Roles)', topbarActions: topbarActions }) %>

                <!-- VIEW: Roles -->
                <section id="view-roles" class="um-view active">
                    <article class="um-table-card">
                        <div class="um-table-toolbar">
                            <input type="text" id="roleSearchFilter" class="um-filter-input" placeholder="ค้นหา role code, ชื่อ...">
                        </div>
                        <div class="um-table-scroll-area">
                            <table class="p-table">
                                <thead>
                                    <tr>
                                        <th>Role</th>
                                        <th>คำอธิบาย</th>
                                        <th>Policies</th>
                                        <th class="um-th-right">จัดการ</th>
                                    </tr>
                                </thead>
                                <tbody id="roleTableBody"></tbody>
                            </table>
                        </div>
                        <%- include('../../components/ui/pager', {
                            infoId: 'rolesPagerInfo',
                            prevId: 'rolesPrevBtn',
                            nextId: 'rolesNextBtn',
                            onPrev: 'goToRolesPage(-1)',
                            onNext: 'goToRolesPage(1)',
                            pageSizeId: 'rolePageSize',
                            pageSizeOptions: [20, 50, 100],
                        }) %>
                    </article>
                </section>

<%- include('../../components/admin-shell/shell-close') %>
<%- include('../../components/layout/page-foot', { pageName: 'roles' }) %>
