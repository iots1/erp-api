<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/<%= prefix %>/assets/css/global.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/<%= prefix %>/assets/pages/roles/css/bundle.css?v=<%= assetVersion %>">
</head>
<body class="um-body">

    <%- include('../../components/admin-shell/login-screen') %>

    <div id="appShell" class="um-shell hidden">
        <%- include('../../components/admin-shell/sidebar', { activeView: 'roles' }) %>

        <main class="um-main">
            <%- include('../../components/admin-shell/topbar', { pageTitle: 'สิทธิ์การใช้งาน (Roles)' }) %>

            <div class="um-content">
                <!-- VIEW: Roles -->
                <section id="view-roles" class="um-view active">
                    <div class="um-toolbar">
                        <h2 class="um-view-title">บทบาทระบบ (System Roles)</h2>
                        <button type="button" class="p-btn p-btn-sky" data-permission="role:create" onclick="openRoleForm(null)">
                            <i data-lucide="plus"></i><span>สร้าง Role</span>
                        </button>
                    </div>
                    <div class="p-card um-table-card">
                        <table class="p-table">
                            <thead>
                                <tr>
                                    <th>Role</th>
                                    <th>คำอธิบาย</th>
                                    <th>Role ID</th>
                                    <th class="um-th-right">จัดการ</th>
                                </tr>
                            </thead>
                            <tbody id="roleTableBody"></tbody>
                        </table>
                    </div>
                </section>

                <!-- VIEW: Role form -->
                <section id="view-role-form" class="um-view">
                    <div class="um-form-header">
                        <button type="button" class="um-icon-btn" onclick="switchView('roles')"><i data-lucide="arrow-left"></i></button>
                        <div>
                            <h2 id="roleFormTitle" class="um-view-title">สร้างบทบาทใหม่ (Create Role)</h2>
                            <p class="um-view-subtitle">กำหนดรายละเอียดบทบาทและแนบนโยบายความปลอดภัย</p>
                        </div>
                    </div>

                    <form id="roleForm" onsubmit="handleRoleFormSubmit(event)">
                        <div class="p-card um-form-section">
                            <div class="um-form-grid">
                                <div class="p-field">
                                    <label for="frmRoleCode">รหัสบทบาท (Role Code) <span class="required">*</span></label>
                                    <input type="text" id="frmRoleCode" class="p-input um-mono-input" required placeholder="เช่น ROLE_WAREHOUSE_MANAGER">
                                </div>
                                <div class="p-field">
                                    <label for="frmRoleNameTh">ชื่อบทบาท (ไทย) <span class="required">*</span></label>
                                    <input type="text" id="frmRoleNameTh" class="p-input" required>
                                </div>
                                <div class="p-field">
                                    <label for="frmRoleNameEn">ชื่อบทบาท (English) <span class="required">*</span></label>
                                    <input type="text" id="frmRoleNameEn" class="p-input" required>
                                </div>
                                <div class="p-field um-field-span-2">
                                    <label for="frmRoleDescription">คำอธิบาย</label>
                                    <textarea id="frmRoleDescription" class="p-textarea" rows="2"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="p-card um-form-section">
                            <h3 class="um-section-title">เลือกนโยบายความปลอดภัย (Attach Policies)</h3>
                            <div id="rolePoliciesContainer" class="um-checkbox-grid"></div>
                        </div>

                        <div class="um-form-actions">
                            <button type="button" class="p-btn" onclick="switchView('roles')">ยกเลิก</button>
                            <button type="submit" class="p-btn p-btn-sky">บันทึกบทบาท</button>
                        </div>
                    </form>
                </section>
            </div>
        </main>
    </div>

    <div id="toastStack" class="p-toast-stack"></div>

    <link rel="stylesheet" href="/<%= prefix %>/assets/css/auth-modal.css?v=<%= assetVersion %>">
    <%- include('../../components/auth-modal') %>

    <%- include('../user-management/components/config') %>
    <script src="/<%= prefix %>/assets/pages/roles/js/bundle.js?v=<%= assetVersion %>"></script>
</body>
</html>
