<%- include('../../components/layout/page-head', { pageName: 'roles' }) %>
<%- include('../../components/admin-shell/shell-open', { activeView: 'roles', pageTitle: 'สิทธิ์การใช้งาน (Roles)' }) %>

                <!-- VIEW: Roles -->
                <section id="view-roles" class="um-view active">
                    <%- include('../../components/ui/toolbar-action-button', {
                        btnClass: 'p-btn p-btn-sky',
                        icon: 'plus',
                        label: 'สร้าง Role',
                        onClick: 'openRoleForm(null)',
                        permission: 'role:create',
                    }) %>
                    <article class="um-table-card">
                        <div class="um-table-scroll-area">
                            <table class="p-table">
                                <thead>
                                    <tr>
                                        <th>Role</th>
                                        <th>คำอธิบาย</th>
                                        <th>Role ID</th>
                                        <th class="um-th-right">จัดการ</th>
                                    </tr>
                                </thead>
                                <tbody id="roleTableBody"></tbody>
                            </table>
                        </div>
                    </article>
                </section>

                <!-- VIEW: Role form -->
                <section id="view-role-form" class="um-view">
                    <%- include('../../components/ui/form-header', {
                        backView: 'roles',
                        titleId: 'roleFormTitle',
                        titleText: 'สร้างบทบาทใหม่ (Create Role)',
                        subtitleText: 'กำหนดรายละเอียดบทบาทและแนบนโยบายความปลอดภัย',
                    }) %>

                    <form id="roleForm" onsubmit="handleRoleFormSubmit(event)">
                        <article class="um-form-section">
                            <div class="um-form-grid">
                                <%- include('../../components/ui/field', { id: 'frmRoleCode', label: 'รหัสบทบาท (Role Code)', required: true, extraClass: 'um-mono-input', placeholder: 'เช่น ROLE_WAREHOUSE_MANAGER' }) %>
                                <%- include('../../components/ui/field', { id: 'frmRoleNameTh', label: 'ชื่อบทบาท (ไทย)', required: true }) %>
                                <%- include('../../components/ui/field', { id: 'frmRoleNameEn', label: 'ชื่อบทบาท (English)', required: true }) %>
                                <%- include('../../components/ui/field', { id: 'frmRoleDescription', label: 'คำอธิบาย', rows: 2, spanClass: 'um-field-span-2' }) %>
                            </div>
                        </article>

                        <article class="um-form-section">
                            <h3 class="um-section-title">เลือกนโยบายความปลอดภัย (Attach Policies)</h3>
                            <div id="rolePoliciesContainer" class="um-checkbox-grid"></div>
                        </article>

                        <div class="um-form-actions">
                            <button type="button" class="p-btn" onclick="switchView('roles')">ยกเลิก</button>
                            <button type="submit" class="p-btn p-btn-sky">บันทึกบทบาท</button>
                        </div>
                    </form>
                </section>

<%- include('../../components/admin-shell/shell-close') %>
<%- include('../../components/layout/page-foot', { pageName: 'roles' }) %>
