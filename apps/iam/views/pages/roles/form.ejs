<%- include('../../components/layout/page-head', { pageName: 'roles' }) %>
<%
const isEdit = !!roleId;
const parentCrumb = { label: 'สิทธิ์การใช้งาน (Roles)', href: `/${prefix}/views/roles` };
const topbarActions = [
    { btnClass: 'p-btn p-btn-sky p-btn-sm', icon: 'save', label: 'บันทึก', onClick: "document.getElementById('roleForm').requestSubmit()" },
];
%>
<%- include('../../components/admin-shell/shell-open', { activeView: 'roles', pageTitle: isEdit ? 'แก้ไขสิทธิ์การใช้งาน' : 'เพิ่มสิทธิ์การใช้งานใหม่', parentCrumb: parentCrumb, topbarActions: topbarActions }) %>

                <!-- VIEW: Role form -->
                <section id="view-role-form" class="um-view active" data-role-id="<%= roleId ?? '' %>">
                    <%- include('../../components/ui/form-header', {
                        backHref: `/${prefix}/views/roles`,
                        titleId: 'roleFormTitle',
                        titleText: isEdit ? 'แก้ไขบทบาท (Edit Role)' : 'สร้างบทบาทใหม่ (Create Role)',
                        subtitleText: 'กำหนดรายละเอียดบทบาทและแนบนโยบายความปลอดภัย',
                    }) %>

                    <form id="roleForm" onsubmit="handleRoleFormSubmit(event)">
                        <article class="um-form-section">
                            <div class="um-form-grid">
                                <%- include('../../components/ui/field', { id: 'frmRoleCode', label: 'รหัสบทบาท (Role Code)', required: true, extraClass: 'um-mono-input', placeholder: 'เช่น ROLE_WAREHOUSE_MANAGER' }) %>
                                <%- include('../../components/ui/field', { id: 'frmRoleNameTh', label: 'ชื่อบทบาท (ไทย)', required: true }) %>
                                <%- include('../../components/ui/field', { id: 'frmRoleNameEn', label: 'ชื่อบทบาท (English)', required: true }) %>
                            </div>
                            <div class="um-form-grid um-form-grid-half">
                                <%- include('../../components/ui/field', { id: 'frmRoleDescription', label: 'คำอธิบาย', rows: 2 }) %>
                            </div>
                        </article>

                        <article class="um-form-section">
                            <h3 class="um-section-title">เลือกนโยบายความปลอดภัย (Attach Policies)</h3>
                            <div id="rolePoliciesContainer" class="um-checkbox-grid um-checkbox-grid-compact"></div>
                        </article>
                    </form>
                </section>

<%- include('../../components/admin-shell/shell-close') %>
<%- include('../../components/layout/page-foot', { pageName: 'roles' }) %>
