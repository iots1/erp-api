<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/<%= prefix %>/assets/css/global.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/<%= prefix %>/assets/pages/sessions/css/bundle.css?v=<%= assetVersion %>">
</head>
<body class="um-body">

    <%- include('../../components/admin-shell/login-screen') %>

    <div id="appShell" class="um-shell hidden">
        <%- include('../../components/admin-shell/sidebar', { activeView: 'sessions' }) %>

        <main class="um-main">
            <%- include('../../components/admin-shell/topbar', { pageTitle: 'ผู้ใช้งานที่ออนไลน์' }) %>

            <div class="um-content">
                <section id="view-sessions" class="um-view active">
                    <div class="um-toolbar">
                        <h2 class="um-view-title">ผู้ใช้งานที่กำลังออนไลน์ (Active Sessions)</h2>
                        <button type="button" class="p-btn p-btn-ghost" onclick="loadSessions(1)">
                            <i data-lucide="refresh-cw"></i><span>รีเฟรช</span>
                        </button>
                    </div>
                    <p class="um-view-subtitle">
                        รายการนี้อ่านจาก session ที่ยังไม่หมดอายุใน Redis — กด "Revoke" เพื่อบังคับออกจากระบบทันที
                    </p>

                    <div class="p-card um-table-card">
                        <table class="p-table">
                            <thead>
                                <tr>
                                    <th>ผู้ใช้งาน</th>
                                    <th>Session ID (jti)</th>
                                    <th>หมดอายุใน</th>
                                    <th class="um-th-right">จัดการ</th>
                                </tr>
                            </thead>
                            <tbody id="sessionsTableBody"></tbody>
                        </table>
                        <div class="um-pager">
                            <span id="sessionsPagerInfo"></span>
                            <button type="button" class="p-btn p-btn-ghost p-btn-sm" id="sessionsPrevBtn" onclick="goToSessionsPage(-1)">
                                <i data-lucide="chevron-left" class="um-icon-sm"></i> ก่อนหน้า
                            </button>
                            <button type="button" class="p-btn p-btn-ghost p-btn-sm" id="sessionsNextBtn" onclick="goToSessionsPage(1)">
                                ถัดไป <i data-lucide="chevron-right" class="um-icon-sm"></i>
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <div id="toastStack" class="p-toast-stack"></div>

    <link rel="stylesheet" href="/<%= prefix %>/assets/css/auth-modal.css?v=<%= assetVersion %>">
    <%- include('../../components/auth-modal') %>

    <%- include('../user-management/components/config') %>
    <script src="/<%= prefix %>/assets/pages/sessions/js/bundle.js?v=<%= assetVersion %>"></script>
</body>
</html>
