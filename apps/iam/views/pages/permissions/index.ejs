<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/<%= prefix %>/assets/css/global.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/<%= prefix %>/assets/pages/permissions/css/bundle.css?v=<%= assetVersion %>">
</head>
<body class="um-body">

    <%- include('../../components/admin-shell/login-screen') %>

    <div id="appShell" class="um-shell hidden">
        <%- include('../../components/admin-shell/sidebar', { activeView: 'permissions' }) %>

        <main class="um-main">
            <%- include('../../components/admin-shell/topbar', { pageTitle: 'จัดการสิทธิ์ (Permissions)' }) %>

            <div class="um-content">
                <section id="view-permissions" class="um-view active">
                    <div class="um-toolbar">
                        <div class="um-toolbar-left">
                            <button type="button" class="p-btn p-btn-sky" data-permission="permission:create" onclick="openPermissionModal()">
                                <i data-lucide="plus"></i><span>เพิ่มสิทธิ์</span>
                            </button>
                            <input type="text" id="permSearchFilter" class="p-input um-filter-input" placeholder="ค้นหา service, permission, ชื่อ...">
                            <select id="permServiceFilter" class="p-select">
                                <option value="">ทุก service</option>
                            </select>
                            <select id="permPlaneFilter" class="p-select">
                                <option value="">ทุก plane</option>
                                <option value="ui">UI</option>
                                <option value="api">API</option>
                            </select>
                            <select id="permSourceFilter" class="p-select">
                                <option value="">ทุกที่มา</option>
                                <option value="manual">Manual</option>
                                <option value="synced">Synced</option>
                            </select>
                        </div>
                    </div>
                    <p class="um-view-subtitle">Plane <b>api</b> มาจาก <span class="mono">@RequirePermission()</span> ในโค้ดเท่านั้น แก้ชื่อได้แต่ลบไม่ได้ที่นี่ — ลบได้เฉพาะสิทธิ์ที่เพิ่มด้วยตนเอง (Manual)</p>

                    <div class="p-card um-table-card">
                        <table class="p-table">
                            <thead>
                                <tr>
                                    <th>Plane</th>
                                    <th>Service / Permission</th>
                                    <th>ชื่อ (TH / EN)</th>
                                    <th>ที่มา</th>
                                    <th class="um-th-right">จัดการ</th>
                                </tr>
                            </thead>
                            <tbody id="permissionsTableBody"></tbody>
                        </table>
                        <div class="um-pager">
                            <div class="um-pager-size">
                                <label for="permPageSize">แสดงต่อหน้า</label>
                                <select id="permPageSize" class="p-select">
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                    <option value="1000">1000</option>
                                </select>
                            </div>
                            <div class="um-pager-nav">
                                <span id="permissionsPagerInfo" class="um-pager-pages"></span>
                                <button type="button" class="p-btn p-btn-ghost p-btn-sm" id="permissionsPrevBtn" onclick="goToPermissionsPage(-1)">
                                    <i data-lucide="chevron-left" class="um-icon-sm"></i> ก่อนหน้า
                                </button>
                                <button type="button" class="p-btn p-btn-ghost p-btn-sm" id="permissionsNextBtn" onclick="goToPermissionsPage(1)">
                                    ถัดไป <i data-lucide="chevron-right" class="um-icon-sm"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <!-- Modal: Add / edit permission -->
    <div id="permissionFormModal" class="p-modal-overlay hidden">
        <div class="p-modal-card">
            <div class="p-modal-head">
                <h3 id="permissionFormTitle">เพิ่มสิทธิ์ด้วยตนเอง</h3>
                <button type="button" class="um-icon-btn" onclick="closePermissionModal()"><i data-lucide="x"></i></button>
            </div>
            <form id="permissionForm" onsubmit="handlePermissionFormSubmit(event)">
                <div class="p-modal-body">
                    <p id="permIdentityHint" class="um-muted-note hidden">สิทธิ์นี้ sync มาจากโค้ด — แก้ได้เฉพาะชื่อที่แสดงผล ส่วน service/permission ต้องแก้ที่ source แล้วรัน permissions:sync</p>
                    <div class="p-field">
                        <label for="frmPermService">Service <span class="required">*</span></label>
                        <input type="text" id="frmPermService" class="p-input um-mono-input" required placeholder="เช่น iam, inventory-bc">
                    </div>
                    <div class="p-field">
                        <label for="frmPermPermission">Permission <span class="required">*</span></label>
                        <input type="text" id="frmPermPermission" class="p-input um-mono-input" required placeholder="page:view_reports หรือ component:btn_x">
                    </div>
                    <div class="p-field">
                        <label for="frmPermNameTh">ชื่อ (ไทย) <span class="required">*</span></label>
                        <input type="text" id="frmPermNameTh" class="p-input" required>
                    </div>
                    <div class="p-field">
                        <label for="frmPermNameEn">ชื่อ (English) <span class="required">*</span></label>
                        <input type="text" id="frmPermNameEn" class="p-input" required>
                    </div>
                </div>
                <div class="p-modal-foot">
                    <button type="button" class="p-btn" onclick="closePermissionModal()">ยกเลิก</button>
                    <button type="submit" class="p-btn p-btn-sky">บันทึก</button>
                </div>
            </form>
        </div>
    </div>

    <div id="toastStack" class="p-toast-stack"></div>

    <link rel="stylesheet" href="/<%= prefix %>/assets/css/auth-modal.css?v=<%= assetVersion %>">
    <%- include('../../components/auth-modal') %>

    <%- include('../user-management/components/config') %>
    <script src="/<%= prefix %>/assets/pages/permissions/js/bundle.js?v=<%= assetVersion %>"></script>
</body>
</html>
