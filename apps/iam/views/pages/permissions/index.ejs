<%- include('../../components/layout/page-head', { pageName: 'permissions' }) %>
<%
const topbarActions = [
    { btnClass: 'p-btn p-btn-sky p-btn-sm', icon: 'plus', label: 'เพิ่มสิทธิ์', onClick: 'openPermissionModal()', permission: 'permission:create' },
];
%>
<%- include('../../components/admin-shell/shell-open', { activeView: 'permissions', pageTitle: 'จัดการสิทธิ์ (Permissions)', topbarActions: topbarActions }) %>

                <section id="view-permissions" class="um-view active">
                    <p class="um-view-subtitle">Plane <b>api</b> มาจาก <span class="mono">@RequirePermission()</span> ในโค้ดเท่านั้น แก้ชื่อได้แต่ลบไม่ได้ที่นี่ — ลบได้เฉพาะสิทธิ์ที่เพิ่มด้วยตนเอง (Manual)</p>

                    <article class="um-table-card">
                        <div class="um-table-toolbar">
                            <input type="text" id="permSearchFilter" class="um-filter-input" placeholder="ค้นหา service, permission, ชื่อ...">
                            <select id="permServiceFilter">
                                <option value="">ทุก service</option>
                            </select>
                            <select id="permPlaneFilter">
                                <option value="">ทุก plane</option>
                                <option value="ui">UI</option>
                                <option value="api">API</option>
                            </select>
                            <select id="permSourceFilter">
                                <option value="">ทุกที่มา</option>
                                <option value="manual">Manual</option>
                                <option value="synced">Synced</option>
                            </select>
                        </div>
                        <div class="um-table-scroll-area">
                            <table class="p-table">
                                <thead>
                                    <tr>
                                        <th>Plane</th>
                                        <th>Service</th>
                                        <th>Permission</th>
                                        <th>ชื่อ (TH / EN)</th>
                                        <th>ที่มา</th>
                                        <th class="um-th-right">จัดการ</th>
                                    </tr>
                                </thead>
                                <tbody id="permissionsTableBody"></tbody>
                            </table>
                        </div>
                        <%- include('../../components/ui/pager', {
                            infoId: 'permissionsPagerInfo',
                            prevId: 'permissionsPrevBtn',
                            nextId: 'permissionsNextBtn',
                            onPrev: 'goToPermissionsPage(-1)',
                            onNext: 'goToPermissionsPage(1)',
                            pageSizeId: 'permPageSize',
                            pageSizeOptions: [20, 50, 100, 1000],
                        }) %>
                    </article>
                </section>

<%- include('../../components/admin-shell/shell-close') %>

    <!-- Modal: Add / edit permission -->
    <dialog id="permissionFormModal">
        <article>
            <%- include('../../components/ui/modal-head', { titleId: 'permissionFormTitle', titleText: 'เพิ่มสิทธิ์ด้วยตนเอง', onClose: 'closePermissionModal()' }) %>
            <form id="permissionForm" onsubmit="handlePermissionFormSubmit(event)">
                <p id="permIdentityHint" class="um-muted-note hidden">สิทธิ์นี้ sync มาจากโค้ด — แก้ได้เฉพาะชื่อที่แสดงผล ส่วน service/permission ต้องแก้ที่ source แล้วรัน permissions:sync</p>
                <div class="um-form-grid">
                    <%- include('../../components/ui/field', { id: 'frmPermService', label: 'Service', required: true, extraClass: 'um-mono-input', placeholder: 'เช่น iam, inventory-bc' }) %>
                    <%- include('../../components/ui/field', { id: 'frmPermPermission', label: 'Permission', required: true, extraClass: 'um-mono-input', placeholder: 'page:view_reports หรือ component:btn_x' }) %>
                    <%- include('../../components/ui/field', { id: 'frmPermNameTh', label: 'ชื่อ (ไทย)', required: true }) %>
                    <%- include('../../components/ui/field', { id: 'frmPermNameEn', label: 'ชื่อ (English)', required: true }) %>
                </div>
                <footer>
                    <button type="button" class="p-btn" onclick="closePermissionModal()">ยกเลิก</button>
                    <button type="submit" class="p-btn p-btn-sky">บันทึก</button>
                </footer>
            </form>
        </article>
    </dialog>

<%- include('../../components/layout/page-foot', { pageName: 'permissions' }) %>
