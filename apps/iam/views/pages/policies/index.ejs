<%- include('../../components/layout/page-head', { pageName: 'policies' }) %>
<%
const topbarActions = [
    { btnClass: 'p-btn p-btn-sky p-btn-sm', icon: 'file-json', label: 'สร้าง Policy ใหม่', onClick: `location.href='/${prefix}/views/policies/new'`, permission: 'policy:create' },
];
%>
<%- include('../../components/admin-shell/shell-open', { activeView: 'policies', pageTitle: 'นโยบายความปลอดภัย', topbarActions: topbarActions }) %>

                <!-- VIEW: Policies -->
                <section id="view-policies" class="um-view active">
                    <article class="um-table-card">
                        <div class="um-table-toolbar">
                            <input type="text" id="policySearchFilter" class="um-filter-input" placeholder="ค้นหา code, ชื่อ...">
                            <select id="policyStatusFilter">
                                <option value="">ทุกสถานะ</option>
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="um-table-scroll-area">
                            <table class="p-table">
                                <thead>
                                    <tr>
                                        <th>Policy</th>
                                        <th>รหัส Policy</th>
                                        <th>สถานะ</th>
                                        <th class="um-th-right">จัดการ</th>
                                    </tr>
                                </thead>
                                <tbody id="policyTableBody"></tbody>
                            </table>
                        </div>
                        <%- include('../../components/ui/pager', {
                            infoId: 'policiesPagerInfo',
                            prevId: 'policiesPrevBtn',
                            nextId: 'policiesNextBtn',
                            onPrev: 'goToPoliciesPage(-1)',
                            onNext: 'goToPoliciesPage(1)',
                            pageSizeId: 'policyPageSize',
                            pageSizeOptions: [20, 50, 100],
                        }) %>
                    </article>
                </section>

<%- include('../../components/admin-shell/shell-close') %>
<%- include('../../components/layout/page-foot', { pageName: 'policies' }) %>
