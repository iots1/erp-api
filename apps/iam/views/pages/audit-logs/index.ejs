<%- include('../../components/layout/page-head', { pageName: 'audit-logs' }) %>
<%- include('../../components/admin-shell/shell-open', { activeView: 'audit-logs', pageTitle: 'ประวัติการเข้าใช้งาน (Login History)' }) %>

                <section id="view-audit-logs" class="um-view active">
                    <article class="um-table-card">
                        <div class="um-table-toolbar">
                            <input type="text" id="auditUsernameFilter" class="um-filter-input" placeholder="ค้นหาชื่อผู้ใช้งาน...">
                            <select id="auditResultFilter">
                                <option value="">ทั้งหมด</option>
                                <option value="success">สำเร็จ</option>
                                <option value="failed">ล้มเหลว</option>
                            </select>
                        </div>
                        <div class="um-table-scroll-area">
                            <table class="p-table">
                                <thead>
                                    <tr>
                                        <th>ผู้ใช้งาน</th>
                                        <th>IP Address</th>
                                        <th>User Agent</th>
                                        <th>ผลลัพธ์</th>
                                        <th>เวลาเข้าใช้งาน</th>
                                    </tr>
                                </thead>
                                <tbody id="auditLogTableBody"></tbody>
                            </table>
                        </div>
                        <%- include('../../components/ui/pager', {
                            infoId: 'auditLogPagerInfo',
                            prevId: 'auditLogPrevBtn',
                            nextId: 'auditLogNextBtn',
                            onPrev: 'goToLoginHistoriesPage(-1)',
                            onNext: 'goToLoginHistoriesPage(1)',
                            pageSizeId: 'auditLogPageSize',
                            pageSizeOptions: [15, 30, 50, 100],
                        }) %>
                    </article>
                </section>

<%- include('../../components/admin-shell/shell-close') %>
<%- include('../../components/layout/page-foot', { pageName: 'audit-logs' }) %>
