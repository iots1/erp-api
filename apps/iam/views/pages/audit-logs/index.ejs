<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/<%= prefix %>/assets/css/global.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/<%= prefix %>/assets/pages/audit-logs/css/bundle.css?v=<%= assetVersion %>">
</head>
<body class="um-body">

    <%- include('../../components/admin-shell/login-screen') %>

    <div id="appShell" class="um-shell hidden">
        <%- include('../../components/admin-shell/sidebar', { activeView: 'audit-logs' }) %>

        <main class="um-main">
            <%- include('../../components/admin-shell/topbar', { pageTitle: 'ประวัติการเข้าใช้งาน (Login History)' }) %>

            <div class="um-content">
                <section id="view-audit-logs" class="um-view active">
                    <div class="um-toolbar">
                        <h2 class="um-view-title">ประวัติการเข้าใช้งาน (Login History)</h2>
                        <div class="um-toolbar-left">
                            <input type="text" id="auditUsernameFilter" class="p-input um-filter-input" placeholder="ค้นหาชื่อผู้ใช้งาน...">
                            <select id="auditResultFilter" class="p-select">
                                <option value="">ทั้งหมด</option>
                                <option value="success">สำเร็จ</option>
                                <option value="failed">ล้มเหลว</option>
                            </select>
                        </div>
                    </div>

                    <div class="p-card um-table-card">
                        <table class="p-table">
                            <thead>
                                <tr>
                                    <th>ผู้ใช้งาน</th>
                                    <th>IP Address</th>
                                    <th>User Agent</th>
                                    <th>ผลลัพธ์</th>
                                    <th>เวลาเข้าใช้งาน</th>
                                </tr>
                            </thead>
                            <tbody id="auditLogTableBody"></tbody>
                        </table>
                        <div class="um-pager">
                            <span id="auditLogPagerInfo"></span>
                            <button type="button" class="p-btn p-btn-ghost p-btn-sm" id="auditLogPrevBtn" onclick="goToLoginHistoriesPage(-1)">
                                <i data-lucide="chevron-left" class="um-icon-sm"></i> ก่อนหน้า
                            </button>
                            <button type="button" class="p-btn p-btn-ghost p-btn-sm" id="auditLogNextBtn" onclick="goToLoginHistoriesPage(1)">
                                ถัดไป <i data-lucide="chevron-right" class="um-icon-sm"></i>
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <div id="toastStack" class="p-toast-stack"></div>

    <link rel="stylesheet" href="/<%= prefix %>/assets/css/auth-modal.css?v=<%= assetVersion %>">
    <%- include('../../components/auth-modal') %>

    <%- include('../user-management/components/config') %>
    <script src="/<%= prefix %>/assets/pages/audit-logs/js/bundle.js?v=<%= assetVersion %>"></script>
</body>
</html>
