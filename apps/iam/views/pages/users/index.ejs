<%- include('../../components/layout/page-head', { pageName: 'users' }) %>
<%
const topbarActions = [
    { btnClass: 'p-btn p-btn-sky p-btn-sm', icon: 'plus', label: 'เพิ่มบุคลากร', onClick: 'openUserFormModal()', permission: 'component:btn_add_user' },
];
%>
<%- include('../../components/admin-shell/shell-open', { activeView: 'users', pageTitle: 'จัดการผู้ใช้งาน', topbarActions: topbarActions }) %>

                <section id="view-users" class="um-view active">
                    <article class="um-table-card">
                        <div class="um-table-toolbar">
                            <input type="text" id="filterSearch" class="um-filter-input" placeholder="ค้นหา username, ชื่อ-นามสกุล, อีเมล...">
                            <input type="text" id="filterDept" class="um-filter-input" placeholder="กรองตามแผนก (Department)...">
                            <select id="filterStatus">
                                <option value="">ทุกสถานะ</option>
                                <option value="pending">Pending</option>
                                <option value="active">Active</option>
                                <option value="suspended">Suspended</option>
                            </select>
                        </div>
                        <div class="um-table-scroll-area">
                            <table class="p-table">
                                <thead>
                                    <tr>
                                        <th>ผู้ใช้งาน</th>
                                        <th>รหัสพนักงาน</th>
                                        <th>แผนก</th>
                                        <th>บทบาท</th>
                                        <th>สถานะ</th>
                                        <th class="um-th-right">จัดการ</th>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody"></tbody>
                            </table>
                        </div>
                        <%- include('../../components/ui/pager', {
                            infoId: 'usersPagerInfo',
                            prevId: 'usersPrevBtn',
                            nextId: 'usersNextBtn',
                            onPrev: 'goToUsersPage(-1)',
                            onNext: 'goToUsersPage(1)',
                            pageSizeId: 'usersPageSize',
                            pageSizeOptions: [10, 20, 50, 100],
                        }) %>
                    </article>
                </section>

<%- include('../../components/admin-shell/shell-close') %>

    <!-- Modal: Add / edit user -->
    <dialog id="userFormModal">
        <article>
            <%- include('../../components/ui/modal-head', { titleId: 'userFormTitle', titleText: 'เพิ่มบุคลากร', onClose: 'closeUserFormModal()' }) %>
            <form id="userForm" onsubmit="handleUserFormSubmit(event)">
                <div class="um-form-grid">
                    <%- include('../../components/ui/field', { id: 'frmUsername', label: 'ชื่อผู้ใช้งาน (Username)', required: true }) %>
                    <%- include('../../components/ui/field', { id: 'frmEmployeeId', label: 'รหัสพนักงาน', required: true }) %>
                    <%- include('../../components/ui/field', { id: 'frmFullName', label: 'ชื่อ-นามสกุล', required: true }) %>
                    <%- include('../../components/ui/field', { id: 'frmEmail', label: 'อีเมล', type: 'email' }) %>
                    <%- include('../../components/ui/field', { id: 'frmDepartment', label: 'แผนก/สังกัด' }) %>
                    <div class="p-field">
                        <label for="frmStatus">สถานะ</label>
                        <select id="frmStatus">
                            <option value="pending">Pending</option>
                            <option value="active">Active</option>
                            <option value="suspended">Suspended</option>
                        </select>
                    </div>
                </div>
                <footer>
                    <button type="button" class="p-btn" onclick="closeUserFormModal()">ยกเลิก</button>
                    <button type="submit" class="p-btn p-btn-sky">บันทึก</button>
                </footer>
            </form>
        </article>
    </dialog>

    <!-- Modal: Assign roles -->
    <dialog id="userRolesModal">
        <article>
            <%- include('../../components/ui/modal-head', { titleText: 'จัดการบทบาทผู้ใช้งาน', onClose: 'closeUserRolesModal()' }) %>
            <form id="userRolesForm" onsubmit="handleAssignRolesSubmit(event)">
                <div id="userRolesContainer" class="um-checkbox-grid um-checkbox-grid-compact"></div>
                <footer>
                    <button type="button" class="p-btn" onclick="closeUserRolesModal()">ยกเลิก</button>
                    <button type="submit" class="p-btn p-btn-sky">บันทึก</button>
                </footer>
            </form>
        </article>
    </dialog>

<%- include('../../components/layout/page-foot', { pageName: 'users' }) %>
