<%- include('../../components/layout/page-head', { pageName: 'access-keys' }) %>
<%
const isEdit = !!accessKeyId;
const parentCrumb = { label: 'Access Keys', href: `/${prefix}/views/access-keys` };
const topbarActions = [
    { btnClass: 'p-btn p-btn-sky p-btn-sm', icon: 'save', label: 'บันทึก', onClick: "document.getElementById('accessKeyForm').requestSubmit()" },
];
%>
<%- include('../../components/admin-shell/shell-open', { activeView: 'access-keys', pageTitle: isEdit ? 'แก้ไข Access Key' : 'สร้าง Access Key ใหม่', parentCrumb: parentCrumb, topbarActions: topbarActions }) %>

                <!-- VIEW: Access key form -->
                <section id="view-access-key-form" class="um-view active" data-access-key-id="<%= accessKeyId ?? '' %>">
                    <%- include('../../components/ui/form-header', {
                        backHref: `/${prefix}/views/access-keys`,
                        titleId: 'accessKeyFormTitle',
                        titleText: isEdit ? 'แก้ไข Access Key' : 'สร้าง Access Key ใหม่',
                        subtitleText: 'กำหนดรายละเอียด Access Key และแนบนโยบายความปลอดภัย',
                    }) %>

                    <form id="accessKeyForm" onsubmit="handleAccessKeyFormSubmit(event)">
                        <article class="um-form-section">
                            <div class="um-form-grid">
                                <%- include('../../components/ui/field', { id: 'frmAccessKeyName', label: 'ชื่อ Access Key', required: true, placeholder: 'เช่น Warehouse-Integration' }) %>
                                <div class="p-field hidden" id="accessKeyStatusField">
                                    <label for="frmAccessKeyStatus">สถานะ</label>
                                    <select id="frmAccessKeyStatus">
                                        <option value="active">Active</option>
                                        <option value="inactive">Inactive</option>
                                        <option value="revoked">Revoked</option>
                                    </select>
                                </div>
                            </div>
                            <div class="um-form-grid">
                                <div class="p-field">
                                    <label for="frmAccessKeyOwnerType">ประเภทเจ้าของ</label>
                                    <select id="frmAccessKeyOwnerType" onchange="toggleAccessKeyOwnerType()">
                                        <option value="user">User</option>
                                        <option value="service_account">Service Account</option>
                                    </select>
                                </div>
                                <div class="p-field" id="accessKeyOwnerUserWrap">
                                    <label for="frmAccessKeyOwnerUserId">เจ้าของ (User)</label>
                                    <select id="frmAccessKeyOwnerUserId"></select>
                                </div>
                                <div class="p-field hidden" id="accessKeyOwnerServiceWrap">
                                    <label for="frmAccessKeyOwnerServiceId">Service Account (เลือกจากผู้ใช้งาน)</label>
                                    <select id="frmAccessKeyOwnerServiceId"></select>
                                </div>
                            </div>
                            <div class="um-form-grid um-form-grid-half">
                                <%- include('../../components/ui/field', { id: 'frmAccessKeyDescription', label: 'รายละเอียดการใช้งาน', rows: 2 }) %>
                                <div class="p-field">
                                    <label for="frmAccessKeyExpiresAt">วันหมดอายุ (ไม่ระบุ = ไม่มีวันหมดอายุ)</label>
                                    <input type="datetime-local" id="frmAccessKeyExpiresAt">
                                </div>
                            </div>
                        </article>

                        <article class="um-form-section">
                            <h3 class="um-section-title">เลือกนโยบายความปลอดภัย (Attach Policies)</h3>
                            <div id="accessKeyPoliciesContainer" class="um-checkbox-grid um-checkbox-grid-compact"></div>
                        </article>
                    </form>
                </section>

<%- include('../../components/admin-shell/shell-close') %>

    <!-- Modal: Reveal secret key — shown exactly once, right after creation.
         Not a real navigable page (the secret only exists in this one API
         response), so this stays a modal even though the form itself moved
         to a full page — closing it sends the user back to the list. -->
    <dialog id="accessKeySecretModal" data-persistent>
        <article>
            <header>
                <h3>สร้าง Access Key สำเร็จ</h3>
            </header>
            <p class="um-muted-note">
                กรุณาคัดลอก Secret Key และเก็บไว้อย่างปลอดภัยทันที — ระบบจะแสดง Secret Key นี้เพียงครั้งเดียวเท่านั้น
                และไม่สามารถเรียกดูซ้ำได้อีกหลังจากปิดหน้าต่างนี้
            </p>
            <div class="p-field">
                <label for="secretModalAccessKeyId">Access Key ID</label>
                <div class="um-copy-row">
                    <input type="text" id="secretModalAccessKeyId" class="um-mono-input-natural" readonly>
                    <button type="button" class="p-btn p-btn-ghost p-btn-sm" onclick="copyFieldToClipboard('secretModalAccessKeyId', 'Access Key ID')">
                        <i data-lucide="copy" class="um-icon-sm"></i> คัดลอก
                    </button>
                </div>
            </div>
            <div class="p-field">
                <label for="secretModalSecretKey">Secret Key</label>
                <div class="um-copy-row">
                    <input type="text" id="secretModalSecretKey" class="um-mono-input-natural" readonly>
                    <button type="button" class="p-btn p-btn-ghost p-btn-sm" onclick="copyFieldToClipboard('secretModalSecretKey', 'Secret Key')">
                        <i data-lucide="copy" class="um-icon-sm"></i> คัดลอก
                    </button>
                </div>
            </div>
            <footer>
                <button type="button" class="p-btn p-btn-sky" onclick="closeAccessKeySecretModal()">ฉันได้บันทึกข้อมูลนี้แล้ว</button>
            </footer>
        </article>
    </dialog>

<%- include('../../components/layout/page-foot', { pageName: 'access-keys' }) %>
