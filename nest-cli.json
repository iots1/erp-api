{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "packageManager": "pnpm",
  "sourceRoot": "apps/auth/src",
  "monorepo": true,
  "root": "apps/auth",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/auth/tsconfig.app.json",
    "webpackConfigPath": "webpack.config.js"
  },
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "iam": {
      "type": "application",
      "root": "apps/iam",
      "entryFile": "main",
      "sourceRoot": "apps/iam/src",
      "compilerOptions": {
        "tsConfigPath": "apps/iam/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "inventory-bc": {
      "type": "application",
      "root": "apps/inventory-bc",
      "entryFile": "main",
      "sourceRoot": "apps/inventory-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/inventory-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "supplier-bc": {
      "type": "application",
      "root": "apps/supplier-bc",
      "entryFile": "main",
      "sourceRoot": "apps/supplier-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/supplier-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "sales-bc": {
      "type": "application",
      "root": "apps/sales-bc",
      "entryFile": "main",
      "sourceRoot": "apps/sales-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sales-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "finance-bc": {
      "type": "application",
      "root": "apps/finance-bc",
      "entryFile": "main",
      "sourceRoot": "apps/finance-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/finance-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "report-bc": {
      "type": "application",
      "root": "apps/report-bc",
      "entryFile": "main",
      "sourceRoot": "apps/report-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/report-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "storage-bc": {
      "type": "application",
      "root": "apps/storage-bc",
      "entryFile": "main",
      "sourceRoot": "apps/storage-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/storage-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src"
    }
  }
}
